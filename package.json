{
  "name": "game-stats",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "build": "prisma generate && tsx scripts/with-resolved-env.ts next build",
    "start": "next start",
    "lint": "eslint src scripts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "tsx scripts/with-resolved-env.ts prisma migrate dev",
    "db:migrate:deploy": "tsx scripts/with-resolved-env.ts prisma migrate deploy",
    "db:push": "tsx scripts/with-resolved-env.ts prisma db push",
    "db:studio": "tsx scripts/with-resolved-env.ts prisma studio",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:sync:from-prod": "tsx scripts/db-sync.ts prod-to-local",
    "db:sync:to-prod": "tsx scripts/db-sync.ts local-to-prod",
    "ingest:igdb": "tsx scripts/ingest-igdb.ts",
    "ingest:metacritic": "tsx scripts/ingest-metacritic.ts",
    "inngest:dev": "npx inngest-cli@latest dev",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "@upstash/redis": "^1.34.9",
    "cheerio": "^1.0.0",
    "clsx": "^2.1.1",
    "inngest": "^3.35.1",
    "jose": "^6.0.11",
    "lucide-react": "^0.511.0",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.3",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.25.36"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "dotenv": "^16.5.0",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "prettier": "^3.9.4",
    "prisma": "^6.9.0",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}

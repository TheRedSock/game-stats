# --- Database ---
# Production Neon (default for local dev when USE_LOCAL_DB=false)
DATABASE_URL="postgresql://USER:PASS@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
# Prisma directUrl alias — either name works; DIRECT_DATABASE_URL is written at runtime if unset
DATABASE_URL_DIRECT="postgresql://USER:PASS@ep-xxx.REGION.aws.neon.tech/neondb?sslmode=require"
# DIRECT_DATABASE_URL="postgresql://USER:PASS@ep-xxx.REGION.aws.neon.tech/neondb?sslmode=require"

# Local Docker Postgres (see docker-compose.yml)
DATABASE_LOCAL="postgresql://postgres:postgres@localhost:5432/game_stats?schema=public"
# Optional separate direct URL for local (defaults to DATABASE_LOCAL)
# DATABASE_LOCAL_DIRECT="postgresql://postgres:postgres@localhost:5432/game_stats?schema=public"

# true = dev/CLI/migrations use DATABASE_LOCAL; false = use Neon URLs above
USE_LOCAL_DB=false

# --- Twitch / IGDB (required) ---
TWITCH_APP_CLIENT_ID=
TWITCH_APP_CLIENT_SECRET=

# --- Admin access (required in production) ---
ADMIN_PASSWORD=change-me-in-production

# --- Session signing secret (required in production) ---
SESSION_SECRET=generate-a-long-random-string

# --- Inngest (admin background jobs) ---
# Vercel integration sets signing/event keys in production
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=
# Local dev — `pnpm dev` starts Inngest dev server when INNGEST_DEV=1
INNGEST_DEV=1
INNGEST_ENV=development
INNGEST_SERVE_ORIGIN=http://127.0.0.1:3000

# --- Upstash Redis (job cancellation flags; optional but recommended) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Batch sizes (optional) ---
IGDB_SYNC_BATCH_SIZE=100
METACRITIC_SCRAPE_BATCH_SIZE=20
METACRITIC_RESYNC_BATCH_SIZE=20
IGDB_SEED_TOTAL=200
IGDB_SEED_CHUNK_SIZE=10

# --- Job safeguards (Inngest orchestration caps) ---
JOB_MAX_BATCHES=100
JOB_MAX_TOTAL_ITEMS=5000
JOB_REPAIR_BATCH_SIZE=50

# Batch job logging: off | verbose (defaults to verbose when NODE_ENV=development)
BATCH_JOB_LOG=verbose

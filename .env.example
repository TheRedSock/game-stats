# Database (local dev). For local Postgres, set both URLs to the same value.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/game_stats?schema=public"
DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/game_stats?schema=public"

# Production (Neon): use the pooler URL for DATABASE_URL and the direct (non-pooler) host for DIRECT_DATABASE_URL.
# Pooler:   postgresql://USER:PASS@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require
# Direct:   postgresql://USER:PASS@ep-xxx.REGION.aws.neon.tech/neondb?sslmode=require

# Twitch / IGDB (required)
TWITCH_APP_CLIENT_ID=
TWITCH_APP_CLIENT_SECRET=

# Admin access (required in production)
ADMIN_PASSWORD=change-me-in-production

# Session signing secret (required in production)
SESSION_SECRET=generate-a-long-random-string

# Optional: limit batch sizes for serverless
IGDB_SYNC_BATCH_SIZE=100
METACRITIC_SCRAPE_BATCH_SIZE=20
METACRITIC_RESYNC_BATCH_SIZE=20

# Batch job logging: off | verbose (defaults to verbose when NODE_ENV=development)
BATCH_JOB_LOG=verbose
